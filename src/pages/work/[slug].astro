---
import Layout from '../../layouts/Layout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  return caseStudies.map((cs) => ({
    params: { slug: cs.id },
    props: { caseStudy: cs },
  }));
}

const { caseStudy } = Astro.props;
const { Content } = await render(caseStudy);
const { data } = caseStudy;
---

<Layout title={`${data.title} — Sven Read`} description={data.tagline}>
  <article>
    <header class="mx-auto max-w-4xl px-6 md:px-10 pt-20 md:pt-24 pb-12">
      <p class="font-sans text-xs uppercase tracking-[0.2em] text-accent mb-6">
        Case Study
      </p>
      <h1 class="font-display text-4xl md:text-6xl tracking-tight leading-[1.05]">
        {data.title}
      </h1>
      <p class="font-display text-xl md:text-2xl text-muted mt-6 max-w-3xl leading-snug">
        {data.tagline}
      </p>

      <dl class="grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-8 mt-12 pt-8 border-t border-hairline">
        <div>
          <dt class="font-sans text-xs uppercase tracking-[0.15em] text-muted mb-2">Company</dt>
          <dd class="font-sans text-base">{data.company}</dd>
        </div>
        <div>
          <dt class="font-sans text-xs uppercase tracking-[0.15em] text-muted mb-2">Role</dt>
          <dd class="font-sans text-base">{data.role}</dd>
        </div>
        <div>
          <dt class="font-sans text-xs uppercase tracking-[0.15em] text-muted mb-2">When</dt>
          <dd class="font-sans text-base">{data.dates}</dd>
        </div>
        {data.domain && (
          <div>
            <dt class="font-sans text-xs uppercase tracking-[0.15em] text-muted mb-2">Domain</dt>
            <dd class="font-sans text-base">{data.domain}</dd>
          </div>
        )}
      </dl>
    </header>

    <div class="mx-auto max-w-7xl px-6 md:px-10 mb-16 md:mb-24">
      {data.heroImageSecondary && data.heroImageSecondaryAlt ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
          <Image
            src={data.heroImage}
            alt={data.heroImageAlt}
            widths={[600, 1000, 1400]}
            sizes="(max-width: 768px) 100vw, 640px"
            class="w-full h-auto rounded-2xl lightbox-trigger"
          />
          <Image
            src={data.heroImageSecondary}
            alt={data.heroImageSecondaryAlt}
            widths={[600, 1000, 1400]}
            sizes="(max-width: 768px) 100vw, 640px"
            class="w-full h-auto rounded-2xl lightbox-trigger"
          />
        </div>
      ) : (
        <Image
          src={data.heroImage}
          alt={data.heroImageAlt}
          widths={[800, 1400, 2000]}
          sizes="(max-width: 768px) 100vw, 1280px"
          class="w-full h-auto rounded-2xl lightbox-trigger"
        />
      )}
    </div>

    <div class="prose-case mx-auto max-w-3xl px-6 md:px-10">
      <Content />
    </div>

    {data.gallery && data.gallery.length > 0 && (
      <section class="mx-auto max-w-7xl px-6 md:px-10 mt-20 md:mt-28">
        <h2 class="font-sans text-xs uppercase tracking-[0.2em] text-muted mb-10">Selected Visuals</h2>
        <div class="flex flex-col gap-16">
          {data.gallery.map((item) => (
            <figure>
              <Image
                src={item.src}
                alt={item.alt}
                widths={[800, 1400, 2000]}
                sizes="(max-width: 768px) 100vw, 1100px"
                class="w-full h-auto rounded-2xl lightbox-trigger"
              />
              {item.caption && (
                <figcaption class="font-sans text-sm text-muted mt-4 max-w-2xl">
                  {item.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      </section>
    )}
  </article>

  <Lightbox />
</Layout>

<style>
  .prose-case :global(h2) {
    font-family: var(--font-display);
    font-size: 1.875rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .prose-case :global(h3) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .prose-case :global(p) {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    color: var(--color-ink);
  }

  .prose-case :global(p:first-of-type) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.5;
    color: var(--color-ink);
    margin-bottom: 2.5rem;
  }

  .prose-case :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }

  .prose-case :global(ul li) {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.7;
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .prose-case :global(ul li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .prose-case :global(strong) {
    font-weight: 600;
  }

  .prose-case :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
</style>
