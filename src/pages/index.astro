---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import portraitHome from '../assets/portrait-home.jpeg';

const allCaseStudies = await getCollection('case-studies');

const sorted = allCaseStudies.sort((a, b) => {
  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;
  return orderA - orderB;
});
---

<Layout title="Sven Read — Senior Product Designer">
  <section class="mx-auto max-w-6xl px-6 md:px-10 pt-32 md:pt-40 lg:pt-48 pb-24 md:pb-32 lg:pb-40">
    <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] gap-12 md:gap-20 items-start">
      <div class="w-56 md:w-72 lg:w-96 shrink-0">
        <Image
          src={portraitHome}
          alt="Portrait of Sven Read"
          widths={[280, 400, 600, 800]}
          sizes="(max-width: 768px) 224px, (max-width: 1024px) 288px, 384px"
          class="w-full h-auto rounded-2xl"
        />
      </div>
      <div>
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight">
          Designing interfaces for <strong>complex systems</strong> where <strong>clarity</strong> matters.
        </h1>
        <p class="font-display text-xl md:text-2xl text-muted mt-8 max-w-2xl leading-snug">
          Surgical software, building automation, and data-heavy enterprise platforms.
        </p>
        <p class="font-sans text-base text-muted mt-8">
          <strong>Senior Product Designer</strong>, 20+ years. Based near Munich, working remotely.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 md:px-10 pb-24">
    <div class="flex items-center gap-6 mb-16 md:mb-20">
      <div class="flex-1 h-px bg-hairline"></div>
      <h2 class="font-sans text-xs uppercase tracking-[0.2em] text-muted shrink-0">
        Selected Work
      </h2>
      <div class="flex-1 h-px bg-hairline"></div>
    </div>

    <div class="flex flex-col gap-20 md:gap-28">
      {sorted.map((cs, i) => {
        const cardImg = cs.data.cardImage ?? cs.data.heroImage;
        const cardAlt = cs.data.cardImageAlt ?? cs.data.heroImageAlt;
        const imageOrder = i % 2 === 0 ? 'md:order-2' : 'md:order-1';
        const textOrder = i % 2 === 0 ? 'md:order-1' : 'md:order-2';
        return (
          <a href={`/work/${cs.id}`} class="group grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-center">
            <div class={`${imageOrder} aspect-[4/3] overflow-hidden bg-hairline/30 rounded-2xl`}>
              <Image
                src={cardImg}
                alt={cardAlt}
                widths={[500, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 560px"
                class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.01]"
              />
            </div>
            <div class={textOrder}>
              <h3 class="font-display text-3xl md:text-4xl lg:text-5xl tracking-tight leading-[1.1] group-hover:text-accent transition-colors">
                {cs.data.title}
              </h3>
              <p class="font-display text-lg md:text-xl text-muted mt-4 leading-snug">
                {cs.data.tagline}
              </p>
              <p class="font-sans text-xs uppercase tracking-[0.2em] text-muted mt-6">
                {cs.data.company} · {cs.data.dates}
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
