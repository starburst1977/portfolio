    <main>
      <slot />
    </main>

    <footer class="border-t border-hairline mt-32">
      <div class="mx-auto max-w-6xl px-6 md:px-10 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-sm text-muted">
